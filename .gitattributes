# Auto detect text files and perform LF normalization
* text=auto
.gitattributes text eol=lf

# Python
*.py text eol=lf diff=python

# TypeScript/Vue
*.ts text eol=lf
*.vue text eol=lf

# JSON
*.json text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Shell
*.sh text eol=lf

# Batch (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.ico binary
*.svg binary
