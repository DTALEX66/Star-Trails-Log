# Fan Memory OS - Discovery Service Config
# 复制为 .env 后修改

APP_NAME="Fan Memory OS Discovery"
APP_VERSION="0.2.0"
DEBUG=false

# 数据库（SQLite 默认）
DATABASE_URL="sqlite+aiosqlite:///./data/discovery.db"

# RSSHub 地址（可自建或使用公共实例）
RSSHUB_BASE_URL="https://rsshub.app"
REQUEST_TIMEOUT=30

# 调度间隔（分钟）
DISCOVERY_INTERVAL_MINUTES=60
DISCOVERY_ENABLED=true

# CORS
CORS_ORIGINS=["*"]
